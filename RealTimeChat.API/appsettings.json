{
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Issuer": "RealTimeChat",
    "Audience": "RealTimeChatUsers",
    "Key": "",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Concole", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
